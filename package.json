{
  "name": "@raycashxyz/confidential-primitives",
  "version": "0.4.0",
  "description": "Reusable confidential (FHE) smart-contract primitives for the Zama FHEVM: stealth wrap adapters that add recipient privacy to ERC-7984 wrapping, and recurring encrypted allowances for scoped spending delegation.",
  "license": "MIT",
  "packageManager": "pnpm@10.18.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raycashxyz/confidential-primitives.git"
  },
  "keywords": [
    "fhevm",
    "fhe",
    "zama",
    "erc7984",
    "confidential",
    "ethereum",
    "solidity"
  ],
  "files": [
    "contracts/**/*.sol",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bench": "vitest run --config vitest.bench.config.ts",
    "clean": "hardhat clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@fhevm/solidity": "^0.11.1",
    "@openzeppelin/confidential-contracts": "0.5.1",
    "@openzeppelin/contracts": "^5.6.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@deployoor/hardhat": "^0.1.1",
    "@deployoor/testing": "^0.2.2",
    "@fhevm/mock-utils": "^0.4.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.0",
    "@types/node": "^22.18.11",
    "chai": "^4.5.0",
    "deployoor": "^0.3.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.15.0",
    "fhevm-tevm-mocks": "^0.3.0",
    "hardhat": "^2.26.0",
    "tevm": "1.0.0-next.149",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2",
    "viem": "2.44.2",
    "vitest": "4.0.18",
    "zod": "^4.4.3"
  }
}
