# Config only — NEVER put auth tokens here. Publishing is via GitHub Actions OIDC.
#
# Flatten node_modules so Hardhat can resolve transitive Solidity dependencies — e.g.
# `encrypted-types`, a dependency of @fhevm/solidity — that pnpm's default (strict,
# non-hoisted) linker leaves under .pnpm/ where Hardhat's resolver can't find them.
node-linker=hoisted
